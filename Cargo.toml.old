
[package]
name = "audio_bridge"
version = "0.1.0"
edition = "2021"

[dependencies]
cpal = "0.15"
ringbuf = "0.3"
audiopus = { version = "0.3.0-rc.0", features = ["static"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
bincode = "1.3"
eframe = { version = "0.27", features = ["android-native-activity"] }
android-activity = { version = "0.5", features = ["native-activity"] }
egui_plot = "0.27"
egui_extras = { version = "0.27", features = ["all_loaders"] }
machine-uid = "0.3"
sha2 = "0.10"
rand = "0.8"
image = "0.24"

[build-dependencies]
winres = "0.1"
 
[lib]
name = "audio_bridge"
crate-type = ["cdylib"]
path = "src/main.rs"

[patch.crates-io]
# URL decodificato: https://github.com
android-activity = { git = "https://github.com/rust-mobile/android-activity", rev = "v0.5.2" }

